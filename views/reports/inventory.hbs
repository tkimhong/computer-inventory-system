<h2>Inventory Status Report</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 15px; margin-bottom: 30px;">
  <div class="panel" style="border-left: 4px solid var(--text-muted);">
    <div style="font-size: 0.8em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Total Assets</div>
    <div style="font-size: 2.5em; font-weight: bold; margin-top: 10px;">{{stats.total}}</div>
  </div>
  <div class="panel" style="border-left: 4px solid var(--green);">
    <div style="font-size: 0.8em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Available</div>
    <div style="font-size: 2.5em; font-weight: bold; color: var(--green); margin-top: 10px;">{{stats.available}}</div>
  </div>
  <div class="panel" style="border-left: 4px solid var(--amber);">
    <div style="font-size: 0.8em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Deployed (In-Use)</div>
    <div style="font-size: 2.5em; font-weight: bold; color: var(--amber); margin-top: 10px;">{{stats.deployed}}</div>
  </div>
  <div class="panel" style="border-left: 4px solid var(--cyan-main);">
    <div style="font-size: 0.8em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Deployment Rate</div>
    <div style="font-size: 2.5em; font-weight: bold; color: var(--cyan-main); margin-top: 10px;">{{stats.deploymentRate}}%</div>
  </div>
</div>

<div class="panel" style="margin-bottom: 20px;">
  <h3 style="border-bottom: 1px solid var(--border); padding-bottom: 10px;">Asset Breakdown</h3>
  <table>
    <thead>
      <tr>
        <th>Status</th>
        <th style="text-align: center;">Count</th>
        <th style="text-align: center;">Percentage</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>Available</strong></td>
        <td style="text-align: center;">{{stats.available}}</td>
        <td style="text-align: center;">{{#if (gt stats.total 0)}}{{round (mult (div stats.available stats.total) 100) 2}}%{{else}}0%{{/if}}</td>
      </tr>
      <tr>
        <td><strong>In-Use (Deployed)</strong></td>
        <td style="text-align: center;">{{stats.deployed}}</td>
        <td style="text-align: center;">{{#if (gt stats.total 0)}}{{round (mult (div stats.deployed stats.total) 100) 2}}%{{else}}0%{{/if}}</td>
      </tr>
      <tr>
        <td><strong>Maintenance</strong></td>
        <td style="text-align: center;">{{stats.maintenance}}</td>
        <td style="text-align: center;">{{#if (gt stats.total 0)}}{{round (mult (div stats.maintenance stats.total) 100) 2}}%{{else}}0%{{/if}}</td>
      </tr>
      <tr>
        <td><strong>Retired</strong></td>
        <td style="text-align: center;">{{stats.retired}}</td>
        <td style="text-align: center;">{{#if (gt stats.total 0)}}{{round (mult (div stats.retired stats.total) 100) 2}}%{{else}}0%{{/if}}</td>
      </tr>
    </tbody>
  </table>
</div>

<div class="panel">
  <h3 style="border-bottom: 1px solid var(--border); padding-bottom: 10px;">All Assets</h3>
  <table>
    <thead>
      <tr>
        <th>Serial No.</th>
        <th>Brand & Model</th>
        <th>Category</th>
        <th>Status</th>
        <th>Acquired</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td><strong>{{this.serialNumber}}</strong></td>
        <td>{{this.brand}} {{this.model}}</td>
        <td>{{this.category}}</td>
        <td>
          <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.85em; font-weight: bold;
            {{#eq this.status 'Available'}}background: rgba(132,204,22,0.15); color: var(--green);{{/eq}}
            {{#eq this.status 'In-Use'}}background: rgba(245,158,11,0.15); color: var(--amber);{{/eq}}
            {{#eq this.status 'Maintenance'}}background: rgba(220,38,38,0.15); color: var(--red);{{/eq}}
            {{#eq this.status 'Retired'}}background: rgba(148,163,184,0.15); color: var(--text-muted);{{/eq}}
          ">{{this.status}}</span>
        </td>
        <td style="color: var(--text-muted);">{{formatDate this.dateAcquired}}</td>
      </tr>
      {{else}}
      <tr>
        <td colspan="5" style="text-align: center; color: var(--text-muted); font-style: italic; padding: 30px;">No assets found.</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
