<h2>Asset Aging Report</h2>

<div class="alert-error" style="margin-bottom: 20px;">
  <strong>Assets older than 3 years (as of {{threeYearsAgoDate}})</strong>
  <p style="margin: 8px 0 0 0; color: inherit;">
    Found <strong>{{count}}</strong> asset(s) that have exceeded the typical 3-year lifecycle and may require replacement or evaluation.
  </p>
</div>

<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 30px;">
  <div class="panel" style="border-left: 4px solid var(--amber);">
    <div style="font-size: 0.8em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">3-5 Years Old</div>
    <div style="font-size: 2.5em; font-weight: bold; color: var(--amber); margin-top: 10px;">{{breakdown.threeToFive}}</div>
  </div>
  <div class="panel" style="border-left: 4px solid var(--red);">
    <div style="font-size: 0.8em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">5-7 Years Old</div>
    <div style="font-size: 2.5em; font-weight: bold; color: var(--red); margin-top: 10px;">{{breakdown.fiveToSeven}}</div>
  </div>
  <div class="panel" style="border-left: 4px solid rgb(185, 28, 28);">
    <div style="font-size: 0.8em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">7+ Years Old</div>
    <div style="font-size: 2.5em; font-weight: bold; color: var(--red); margin-top: 10px;">{{breakdown.sevenPlus}}</div>
  </div>
</div>

<div class="panel">
  <h3 style="border-bottom: 1px solid var(--border); padding-bottom: 10px;">Detailed Aging Asset List</h3>
  <table>
    <thead>
      <tr>
        <th>Serial No.</th>
        <th>Brand & Model</th>
        <th>Category</th>
        <th>Status</th>
        <th>Acquired</th>
        <th style="text-align: center;">Age (Years)</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td style="color: var(--cyan-main); font-weight: bold;">{{this.serialNumber}}</td>
        <td>{{this.brand}} {{this.model}}</td>
        <td>{{this.category}}</td>
        <td>
          <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.85em; font-weight: bold;
            {{#eq this.status 'Available'}}background: rgba(132,204,22,0.15); color: var(--green);{{/eq}}
            {{#eq this.status 'In-Use'}}background: rgba(245,158,11,0.15); color: var(--amber);{{/eq}}
            {{#eq this.status 'Maintenance'}}background: rgba(220,38,38,0.15); color: var(--red);{{/eq}}
            {{#eq this.status 'Retired'}}background: rgba(148,163,184,0.15); color: var(--text-muted);{{/eq}}
          ">{{this.status}}</span>
        </td>
        <td style="color: var(--text-muted);">{{formatDate this.dateAcquired}}</td>
        <td style="text-align: center; font-weight: bold; color: var(--red);">{{calcAge this.dateAcquired}}</td>
      </tr>
      {{else}}
      <tr>
        <td colspan="6" style="text-align: center; color: var(--text-muted); font-style: italic; padding: 30px;">No aging assets found. All assets are within acceptable lifecycle.</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<div class="alert-success" style="margin-top: 20px;">
  <strong>Recommendation:</strong> Assets exceeding 7+ years should be considered for retirement or replacement to maintain system performance and reliability.
</div>
