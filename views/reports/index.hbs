<h2>Reports Dashboard</h2>

<p style="color: #6c757d; margin-bottom: 30px;">
  Administrative reporting for inventory management and asset lifecycle analysis.
</p>

<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px;">

  <!-- Inventory Status Report Card -->
  <div style="
      background: #ffffff;
      border: 1px solid #dee2e6;
      color: #212529;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: pointer;"
      onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 4px 14px rgba(0,0,0,0.12)';"
      onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
    <a href="/reports/inventory" style="text-decoration: none; color: inherit;">
      <div style="font-size: 2em; margin-bottom: 10px;">📊</div>
      <h3 style="margin: 0 0 10px 0;">Inventory Status</h3>
      <p style="margin: 0 0 15px 0; color: #6c757d;">
        Total Assets: <strong>{{stats.totalItems}}</strong>
      </p>
      <p style="margin: 0; color: #6c757d;">
        Deployed: {{stats.deployedItems}} units
      </p>
    </a>
  </div>

  <!-- Asset Aging Report Card -->
  <div style="
      background: #ffffff;
      border: 1px solid #dee2e6;
      color: #212529;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: pointer;"
      onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 4px 14px rgba(0,0,0,0.12)';"
      onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
    <a href="/reports/aging" style="text-decoration: none; color: inherit;">
      <div style="font-size: 2em; margin-bottom: 10px;">🕐</div>
      <h3 style="margin: 0 0 10px 0;">Asset Aging</h3>
      <p style="margin: 0 0 15px 0; color: #6c757d;">
        Aging (3+ years): <strong>{{stats.agingItems}}</strong>
      </p>
      <p style="margin: 0; color: #6c757d;">
        Lifecycle management
      </p>
    </a>
  </div>

  <!-- User Audit Report Card -->
  <div style="
      background: #ffffff;
      border: 1px solid #dee2e6;
      color: #212529;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: pointer;"
      onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 4px 14px rgba(0,0,0,0.12)';"
      onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
    <a href="/users" style="text-decoration: none; color: inherit;">
      <div style="font-size: 2em; margin-bottom: 10px;">👥</div>
      <h3 style="margin: 0 0 10px 0;">User Audit</h3>
      <p style="margin: 0 0 15px 0; color: #6c757d;">
        Track assets per user
      </p>
      <p style="margin: 0; color: #6c757d;">
        View user assignments
      </p>
    </a>
  </div>

</div>

<div style="
    background: #ffffff;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
  <h3 style="margin-top: 0; color: #212529;">📈 Quick Stats</h3>
  <ul style="list-style: none; padding: 0; margin: 0;">
    <li style="padding: 8px 0; border-bottom: 1px solid #e9ecef;">
      <strong>Total Inventory:</strong> {{stats.totalItems}} items
    </li>
    <li style="padding: 8px 0; border-bottom: 1px solid #e9ecef;">
      <strong>Deployed:</strong> {{stats.deployedItems}} items in use
    </li>
    <li style="padding: 8px 0; border-bottom: 1px solid #e9ecef;">
      <strong>Aging Assets:</strong> {{stats.agingItems}} items (3+ years old)
    </li>
    <li style="padding: 8px 0;">
      <strong>Utilization Rate:</strong>
      {{#if (gt stats.totalItems 0)}}
        {{round (mult (div stats.deployedItems stats.totalItems) 100) 2}}%
      {{else}}
        0%
      {{/if}}
    </li>
  </ul>
</div>