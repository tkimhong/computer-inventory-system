<h2>Reports Dashboard</h2>

<p style="margin-bottom: 30px;">Administrative reporting for inventory management and asset lifecycle analysis.</p>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px;">

  <a href="/reports/inventory" class="panel" style="text-decoration: none; color: inherit; display: block; transition: transform 0.2s; cursor: pointer;"
     onmouseover="this.style.transform='translateY(-4px)'"
     onmouseout="this.style.transform='translateY(0)'">
    <div style="font-size: 2em; margin-bottom: 10px;">📊</div>
    <h3 style="margin: 0 0 10px 0;">Inventory Status</h3>
    <p>Total Assets: <strong>{{stats.totalItems}}</strong></p>
    <p>Deployed: {{stats.deployedItems}} units</p>
  </a>

  <a href="/reports/aging" class="panel" style="text-decoration: none; color: inherit; display: block; transition: transform 0.2s; cursor: pointer;"
     onmouseover="this.style.transform='translateY(-4px)'"
     onmouseout="this.style.transform='translateY(0)'">
    <div style="font-size: 2em; margin-bottom: 10px;">🕐</div>
    <h3 style="margin: 0 0 10px 0;">Asset Aging</h3>
    <p>Aging (3+ years): <strong>{{stats.agingItems}}</strong></p>
    <p>Lifecycle management</p>
  </a>

  <a href="/reports/users" class="panel" style="text-decoration: none; color: inherit; display: block; transition: transform 0.2s; cursor: pointer;"
     onmouseover="this.style.transform='translateY(-4px)'"
     onmouseout="this.style.transform='translateY(0)'">
    <div style="font-size: 2em; margin-bottom: 10px;">👥</div>
    <h3 style="margin: 0 0 10px 0;">User Audit</h3>
    <p>Track assets per user</p>
    <p>View user assignments</p>
  </a>

</div>

<div class="panel">
  <h3 style="border-bottom: 1px solid var(--border); padding-bottom: 10px;">Quick Stats</h3>
  <ul style="list-style: none; padding: 0; margin: 0;">
    <li style="padding: 10px 0; border-bottom: 1px solid var(--border);">
      <strong>Total Inventory:</strong> {{stats.totalItems}} items
    </li>
    <li style="padding: 10px 0; border-bottom: 1px solid var(--border);">
      <strong>Deployed:</strong> {{stats.deployedItems}} items in use
    </li>
    <li style="padding: 10px 0; border-bottom: 1px solid var(--border);">
      <strong>Aging Assets:</strong> {{stats.agingItems}} items (3+ years old)
    </li>
    <li style="padding: 10px 0;">
      <strong>Utilization Rate:</strong>
      {{#if (gt stats.totalItems 0)}}
        {{round (mult (div stats.deployedItems stats.totalItems) 100) 2}}%
      {{else}}
        0%
      {{/if}}
    </li>
  </ul>
</div>
