<h2>Transaction History</h2>

<div style="margin-bottom: 20px;">
  <a href="/transactions/checkout" class="btn btn-primary">Check Out</a>
  <a
    href="/transactions/checkin"
    class="btn btn-danger"
    style="margin-left: 8px;"
  >Check In</a>
</div>

<table>
  <thead>
    <tr>
      <th>Action</th>
      <th>Item</th>
      <th>User</th>
      <th>Notes</th>
      <th>Date</th>
      <th>Document</th>
    </tr>
  </thead>
  <tbody>
    {{#each transactions}}
      <tr>
        <td>{{this.action}}</td>
        <td>{{this.item.serialNumber}}</td>
        <td>{{this.user.username}}</td>
        <td>{{this.notes}}</td>
        <td>{{formatDate this.createdAt}}</td>
        <td>
          {{#if this.documentPath}}
            <a href="/{{this.documentPath}}" target="_blank" class="btn btn-primary" style="font-size:0.85em; padding:4px 8px;">View</a>
          {{else}}
            <span style="color:#adb5bd; font-style:italic;">None</span>
          {{/if}}
        </td>
      </tr>
    {{else}}
      <tr>
        <td colspan="6" style="text-align:center; color:#6c757d;">No transactions yet.</td>
      </tr>
    {{/each}}
  </tbody>
</table>