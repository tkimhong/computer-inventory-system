<h1>Check In Item</h1>

{{#if error}}
<div style="background:#f8d7da; color:#721c24; border:1px solid #f5c6cb; padding:12px; border-radius:4px; margin-bottom:16px;">
  ❌ {{error}}
</div>
{{/if}}

<form
  action="/api/transactions/checkin"
  method="POST"
  enctype="multipart/form-data"
>
  <div>
    <label for="itemId">Item ID</label>
    <input type="text" id="itemId" name="itemId" required />
  </div>
  <div>
    <label for="notes">Notes</label>
    <textarea id="notes" name="notes"></textarea>
  </div>
  <div>
    <label for="document">Reference Document</label>
    <input type="file" id="document" name="document" />
  </div>
  <button type="submit">Check In</button>
</form>