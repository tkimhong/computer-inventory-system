<h2>Check In Item</h2>

{{#if error}}
<div class="alert-error">{{error}}</div>
{{/if}}

<div class="panel" style="max-width: 600px;">
  <form action="/api/transactions/checkin" method="POST" enctype="multipart/form-data" style="display: grid; gap: 16px;">
    <div>
      <label for="itemId">Select Item</label>
      <select id="itemId" name="itemId" required>
        <option value="" disabled selected>Select an item to check in...</option>
        {{#each inUseItems}}
          <option value="{{this._id}}">{{this.brand}} {{this.model}} — {{this.serialNumber}}</option>
        {{else}}
          <option disabled>No items currently checked out</option>
        {{/each}}
      </select>
    </div>
    <div>
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" placeholder="Optional notes..."></textarea>
    </div>
    <div>
      <label for="document">Reference Document</label>
      <input type="file" id="document" name="document">
    </div>
    <button type="submit" class="btn btn-primary">Check In</button>
  </form>
</div>
