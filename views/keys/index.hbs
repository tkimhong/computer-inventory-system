<h2>API Key Management</h2>

<!-- Generated Key Alert -->
<div id="keyAlert" style="display:none; margin-bottom:20px; padding:15px; border-radius:8px; background:#fff3cd; border:1px solid #ffc107;">
  <strong>⚠️ Copy this key now — it will never be shown again!</strong>
  <div style="margin-top:10px; display:flex; gap:10px; align-items:center;">
    <code id="rawKeyDisplay" style="flex:1; padding:10px; background:#f8f9fa; border:1px solid #dee2e6; border-radius:4px; word-break:break-all; font-size:13px;"></code>
    <button onclick="copyKey()" class="btn btn-primary" style="white-space:nowrap;">Copy Key</button>
  </div>
</div>

<div id="errorMsg" style="display:none; margin-bottom:15px; padding:10px; border-radius:4px; background:#f8d7da; color:#721c24; border:1px solid #f5c6cb;"></div>

<!-- Generate New API Key -->
<div style="background:#f8f9fa; padding:20px; border-radius:8px; margin-bottom:20px; border:1px solid #dee2e6;">
  <h3>Generate New API Key</h3>
  <div style="display:grid; grid-template-columns:1fr; gap:15px;">
    <input type="text" id="label" placeholder="Key Label / Description (Required)" style="padding:10px;">
    <button onclick="generateKey()" class="btn btn-primary" style="padding:10px;">Generate API Key</button>
  </div>
</div>

<!-- Keys List -->
<h3>Active API Keys</h3>
{{#if keys}}
  <table>
    <thead>
      <tr>
        <th>Label</th>
        <th>Prefix</th>
        <th>Created By</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#each keys}}
        <tr id="keyrow-{{this._id}}">
          <td><strong>{{this.label}}</strong></td>
          <td><code>{{this.keyPrefix}}...</code></td>
          <td>{{this.createdBy.username}}</td>
          <td>{{formatDate this.createdAt}}</td>
          <td>
            <button onclick="revokeKey('{{this._id}}')" class="btn btn-danger" style="padding:5px 8px; font-size:12px;">Revoke</button>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
{{else}}
  <p style="text-align:center; color:#6c757d;">No active API keys. Generate one to get started.</p>
{{/if}}

<script>
async function generateKey() {
  const label = document.getElementById('label').value.trim();
  const errMsg = document.getElementById('errorMsg');
  const keyAlert = document.getElementById('keyAlert');

  if (!label) {
    errMsg.textContent = '❌ Label is required.';
    errMsg.style.display = 'block';
    return;
  }
  errMsg.style.display = 'none';

  try {
    const res = await fetch('/api/keys', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ label })
    });
    const data = await res.json();

    if (res.ok) {
      document.getElementById('rawKeyDisplay').textContent = data.rawKey;
      keyAlert.style.display = 'block';
      keyAlert.scrollIntoView({ behavior: 'smooth' });
      document.getElementById('label').value = '';
      setTimeout(() => location.reload(), 10000); // reload after 10s
    } else {
      errMsg.textContent = `❌ ${data.error || 'Failed to generate key'}`;
      errMsg.style.display = 'block';
    }
  } catch (err) {
    errMsg.textContent = '❌ Network error. Please try again.';
    errMsg.style.display = 'block';
  }
}

function copyKey() {
  const key = document.getElementById('rawKeyDisplay').textContent;
  navigator.clipboard.writeText(key).then(() => alert('✅ Key copied to clipboard!'));
}

async function revokeKey(id) {
  if (!confirm('Are you sure you want to revoke this API key?')) return;

  const res = await fetch(`/api/keys/${id}`, { method: 'DELETE' });
  if (res.ok) {
    document.getElementById(`keyrow-${id}`).remove();
  } else {
    const data = await res.json();
    alert(`❌ Failed to revoke: ${data.error || 'Unknown error'}`);
  }
}
</script>