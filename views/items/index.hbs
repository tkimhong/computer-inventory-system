<h2>Computer Inventory Management</h2>

<div class="panel" style="margin-bottom: 20px;">
  <h3>Add New Asset</h3>
  <form action="/api/items" method="POST" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
    <input type="text" name="serialNumber" placeholder="Serial Number (Required)" required>
    <input type="text" name="brand" placeholder="Brand (e.g., Dell, Apple)" required>
    <input type="text" name="model" placeholder="Model (e.g., XPS 15, MacBook Pro)" required>
    <select name="category" required>
      <option value="" disabled selected>Select Classification...</option>
      <optgroup label="Computers">
        <option value="Laptop">Laptop</option>
        <option value="Desktop">Desktop</option>
        <option value="Server">Server</option>
      </optgroup>
      <optgroup label="Peripherals">
        <option value="Monitor">Monitor</option>
        <option value="Keyboard">Keyboard</option>
        <option value="Mouse">Mouse</option>
      </optgroup>
    </select>

    <select name="status">
      <option value="Available">Available</option>
      <option value="In-Use">In-Use</option>
      <option value="Maintenance">Maintenance</option>
      <option value="Retired">Retired</option>
    </select>

    <input type="date" name="dateAcquired">

    <button type="submit" class="btn btn-primary" style="grid-column: span 2;">Register Asset</button>
  </form>
</div>

<table>
  <thead>
    <tr>
      <th>Serial No.</th>
      <th>Brand & Model</th>
      <th>Category</th>
      <th>Status</th>
      <th>Acquired</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {{#each items}}
    <tr>
      <td><strong>{{this.serialNumber}}</strong></td>
      <td>{{this.brand}} {{this.model}}</td>
      <td>{{this.category}}</td>
      <td>
        <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.85em; font-weight: bold;
          {{#eq this.status 'Available'}}background: rgba(132,204,22,0.15); color: var(--green);{{/eq}}
          {{#eq this.status 'In-Use'}}background: rgba(245,158,11,0.15); color: var(--amber);{{/eq}}
          {{#eq this.status 'Maintenance'}}background: rgba(220,38,38,0.15); color: var(--red);{{/eq}}
          {{#eq this.status 'Retired'}}background: rgba(148,163,184,0.15); color: var(--text-muted);{{/eq}}
        ">{{this.status}}</span>
      </td>
      <td>{{formatDate this.dateAcquired}}</td>
      <td>
        <a href="/items/{{this._id}}/history" class="btn btn-primary" style="margin-right: 5px; font-size: 0.8em;">History</a>
        <button onclick="openEdit('{{this._id}}','{{this.serialNumber}}','{{this.brand}}','{{this.model}}','{{this.category}}','{{this.status}}')" class="btn btn-secondary" style="margin-right:5px; font-size: 0.8em;">Edit</button>
        <button onclick="softDelete('{{this._id}}')" class="btn btn-danger" style="font-size: 0.8em;">Remove</button>
      </td>
    </tr>
    {{else}}
    <tr>
      <td colspan="6" style="text-align: center; padding: 20px;">No active assets found.</td>
    </tr>
    {{/each}}
  </tbody>
</table>

<!-- Edit Modal -->
<div id="editModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:1000; justify-content:center; align-items:center;">
  <div style="background: var(--navy-light); border: 1px solid var(--border); padding:30px; border-radius:12px; width:500px; max-width:90%;">
    <h3>Edit Asset</h3>
    <div id="editMsg" style="display:none; margin-bottom:10px;"></div>
    <input type="hidden" id="editId">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <input type="text" id="editSerial" placeholder="Serial Number">
      <input type="text" id="editBrand" placeholder="Brand">
      <input type="text" id="editModel" placeholder="Model">
      <select id="editCategory">
        <optgroup label="Computers">
          <option value="Laptop">Laptop</option>
          <option value="Desktop">Desktop</option>
          <option value="Server">Server</option>
        </optgroup>
        <optgroup label="Peripherals">
          <option value="Monitor">Monitor</option>
          <option value="Keyboard">Keyboard</option>
          <option value="Mouse">Mouse</option>
        </optgroup>
      </select>
      <select id="editStatus" style="grid-column:span 2;">
        <option value="Available">Available</option>
        <option value="In-Use">In-Use</option>
        <option value="Maintenance">Maintenance</option>
        <option value="Retired">Retired</option>
      </select>
    </div>
    <div style="margin-top:15px; display:flex; gap:10px; justify-content:flex-end;">
      <button onclick="closeEdit()" class="btn btn-secondary">Cancel</button>
      <button onclick="saveEdit()" class="btn btn-primary">Save</button>
    </div>
  </div>
</div>

<script>
  function openEdit(id, serial, brand, model, category, status) {
    document.getElementById('editId').value = id;
    document.getElementById('editSerial').value = serial;
    document.getElementById('editBrand').value = brand;
    document.getElementById('editModel').value = model;
    document.getElementById('editCategory').value = category;
    document.getElementById('editStatus').value = status;
    document.getElementById('editMsg').style.display = 'none';
    document.getElementById('editModal').style.display = 'flex';
  }

  function closeEdit() {
    document.getElementById('editModal').style.display = 'none';
  }

  async function saveEdit() {
    const id = document.getElementById('editId').value;
    const body = {
      serialNumber: document.getElementById('editSerial').value,
      brand: document.getElementById('editBrand').value,
      model: document.getElementById('editModel').value,
      category: document.getElementById('editCategory').value,
      status: document.getElementById('editStatus').value,
    };
    const msg = document.getElementById('editMsg');
    try {
      const res = await fetch(`/api/items/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json();
        msg.className = 'alert-error';
        msg.style.display = 'block';
        msg.textContent = data.error || 'Failed to update item';
      }
    } catch (err) {
      msg.className = 'alert-error';
      msg.style.display = 'block';
      msg.textContent = 'Network error.';
    }
  }

  async function softDelete(id) {
    if (!confirm("Are you sure you want to remove this asset? It will be archived according to company policy.")) return;

    try {
      const response = await fetch(`/api/items/${id}`, { method: 'DELETE' });
      if (response.ok) {
        window.location.reload(); 
      } else {
        alert("Failed to remove item.");
      }
    } catch (error) {
      console.error("Error:", error);
      alert("An error occurred.");
    }
  }
</script>