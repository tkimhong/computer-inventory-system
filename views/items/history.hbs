<div style="margin-bottom: 20px;">
  <a href="/items" class="btn btn-secondary">&larr; Back to Inventory</a>
</div>

<div class="panel" style="margin-bottom: 20px;">
  <h2>Asset History: {{item.brand}} {{item.model}}</h2>
  <p>
    <strong>Serial Number:</strong> {{item.serialNumber}} &nbsp;|&nbsp;
    <strong>Category:</strong> {{item.category}} &nbsp;|&nbsp;
    <strong>Status:</strong> <code>{{item.status}}</code>
  </p>
</div>

<div class="panel">
  <h3 style="border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 0;">Transaction Log</h3>

  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Action</th>
        <th>User</th>
        <th>Duration</th>
        <th>Notes</th>
        <th>Reference File</th>
      </tr>
    </thead>
    <tbody>
      {{#each history}}
      <tr>
        <td style="color: var(--text-muted);">{{formatDate this.createdAt}}</td>
        <td style="text-transform: uppercase; font-size: 0.85em; font-weight: bold; letter-spacing: 0.5px;">{{this.action}}</td>
        <td style="font-weight: bold;">{{this.user.username}}</td>
        <td style="color: var(--text-muted);">{{#if this.duration}}{{this.duration}}{{else}}—{{/if}}</td>
        <td>{{this.notes}}</td>
        <td>
          {{#if this.documentPath}}
            <a href="/{{this.documentPath}}" target="_blank" class="btn btn-primary" style="font-size: 0.85em;">View Document</a>
          {{else}}
            <span style="color: var(--text-muted); font-style: italic;">No file attached</span>
          {{/if}}
        </td>
      </tr>
      {{else}}
      <tr>
        <td colspan="6" style="text-align: center; color: var(--text-muted); font-style: italic; padding: 30px;">No transaction history exists for this asset yet.</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
