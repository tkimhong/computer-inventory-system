<a href="/users" style="text-decoration:none; color:#007bff;">← Back to Users</a>

<h2 style="margin-top:15px;">Assets for <strong>{{user.username}}</strong></h2>
<p style="color:#6c757d;">Role: {{user.role}} &nbsp;|&nbsp; Status: {{#if user.isActive}}Active{{else}}Disabled{{/if}}</p>

{{#if assets}}
  <table>
    <thead>
      <tr>
        <th>Serial Number</th>
        <th>Model</th>
        <th>Brand</th>
        <th>Category</th>
        <th>Item Status</th>
      </tr>
    </thead>
    <tbody>
      {{#each assets}}
        <tr>
          <td>{{this.item.serialNumber}}</td>
          <td>{{this.item.model}}</td>
          <td>{{this.item.brand}}</td>
          <td>{{this.item.category}}</td>
          <td><span style="color:#007bff; font-weight:bold;">{{this.item.status}}</span></td>
        </tr>
      {{/each}}
    </tbody>
  </table>
{{else}}
  <p style="text-align:center; color:#6c757d; margin-top:30px;">No assets currently assigned to this user.</p>
{{/if}}