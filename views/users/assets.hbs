<div style="margin-bottom: 20px;">
  <a href="/users" class="btn btn-secondary">&larr; Back to Users</a>
</div>

<h2>Assets for <strong>{{user.username}}</strong></h2>
<p>Role: {{user.role}} &nbsp;|&nbsp; Status: {{#if user.isActive}}Active{{else}}Disabled{{/if}}</p>

{{#if assets}}
  <table>
    <thead>
      <tr>
        <th>Serial Number</th>
        <th>Model</th>
        <th>Brand</th>
        <th>Category</th>
        <th>Item Status</th>
      </tr>
    </thead>
    <tbody>
      {{#each assets}}
        <tr>
          <td>{{this.item.serialNumber}}</td>
          <td>{{this.item.model}}</td>
          <td>{{this.item.brand}}</td>
          <td>{{this.item.category}}</td>
          <td>
            <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.85em; font-weight: bold;
              {{#eq this.item.status 'Available'}}background: rgba(132,204,22,0.15); color: var(--green);{{/eq}}
              {{#eq this.item.status 'In-Use'}}background: rgba(245,158,11,0.15); color: var(--amber);{{/eq}}
              {{#eq this.item.status 'Maintenance'}}background: rgba(220,38,38,0.15); color: var(--red);{{/eq}}
              {{#eq this.item.status 'Retired'}}background: rgba(148,163,184,0.15); color: var(--text-muted);{{/eq}}
            ">{{this.item.status}}</span>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
{{else}}
  <p style="text-align:center; color: var(--text-muted); margin-top:30px;">No assets currently assigned to this user.</p>
{{/if}}
