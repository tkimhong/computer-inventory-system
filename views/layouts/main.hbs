<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - Computer Inventory</title>
  <link rel="stylesheet" href="/css/index.css">
</head>
<body>

  <nav>
    <a href="/" class="brand">Inventory System</a>
    <a href="/items" {{#if (or (eq title 'Inventory Management') (startsWith title 'Asset History'))}}class="active"{{/if}}>Items</a>
    <a href="/users" {{#if (or (eq title 'User Management') (startsWith title 'Assets for'))}}class="active"{{/if}}>Users</a>
    <a href="/transactions" {{#if (or (eq title 'Transactions') (startsWith title 'Check'))}}class="active"{{/if}}>Transactions</a>
    <a href="/keys" {{#if (eq title 'API Key Management')}}class="active"{{/if}}>Keys</a>
    <a href="/reports" {{#if (or (includes title 'Report') (eq title 'User Audit'))}}class="active"{{/if}}>Reports</a>
    <span class="nav-right">
      <a href="/login/logout">Logout</a>
    </span>
  </nav>

  <div class="container">
    {{{body}}}
  </div>

  <footer style="text-align: center; padding: 20px; color: var(--text-muted); font-size: 0.8rem; border-top: 1px solid var(--border); margin-top: 20px;">
    INF 653 · Group 2 · Computer Inventory System
  </footer>

</body>
</html>
