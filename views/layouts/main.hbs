<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - Computer Inventory</title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: Arial, sans-serif; background-color: #f4f7f6; margin: 0; }

    /* Navbar */
    nav {
      background-color: #343a40;
      padding: 0 30px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    nav .brand {
      color: white;
      font-weight: bold;
      font-size: 18px;
      padding: 16px 0;
      margin-right: 20px;
      text-decoration: none;
    }
    nav a {
      color: #adb5bd;
      text-decoration: none;
      padding: 16px 14px;
      display: inline-block;
      font-size: 14px;
      transition: color 0.2s, background 0.2s;
    }
    nav a:hover { color: white; background: #495057; }
    nav a.active { color: white; border-bottom: 3px solid #007bff; }
    nav .nav-right { margin-left: auto; }

    /* Content */
    .container {
      max-width: 1100px;
      margin: 30px auto;
      background: white;
      padding: 24px;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { padding: 12px; border: 1px solid #ddd; text-align: left; }
    th { background-color: #343a40; color: white; }
    .btn { padding: 6px 12px; border: none; cursor: pointer; border-radius: 4px; color: white; }
    .btn-danger { background-color: #dc3545; }
    .btn-primary { background-color: #007bff; }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="brand">🖥️ Inventory</a>
    <a href="/items" {{#if (eq title 'Inventory')}}class="active"{{/if}}>Items</a>
    <a href="/users" {{#if (eq title 'User Management')}}class="active"{{/if}}>Users</a>
    <a href="/transactions" {{#if (eq title 'Transactions')}}class="active"{{/if}}>Transactions</a>
    <a href="/keys" {{#if (eq title 'Keys')}}class="active"{{/if}}>Keys</a>
    <a href="/reports" {{#if (eq title 'Inventory Status Report')}}class="active"{{/if}}>Reports</a>
    <span class="nav-right">
      <a href="/login/logout">Logout</a>
    </span>
  </nav>

  <div class="container">
    {{{body}}}
  </div>

</body>
</html>